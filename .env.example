# Copy to .env and fill in with your Powens application credentials.
# Get these from the Powens console: https://console.powens.com/

# Your Powens domain — either the short name ("myapp-sandbox") or the full host.
POWENS_DOMAIN=myapp-sandbox

# Application credentials (client_id / client_secret).
POWENS_CLIENT_ID=
POWENS_CLIENT_SECRET=

# Optional: an existing user access token. If omitted, create_user() mints one.
POWENS_ACCESS_TOKEN=

# --- Application (optional) ---
# APP_HOST=127.0.0.1
# APP_PORT=8000
# APP_HISTORY_MONTHS=24   # sliding window (months) used for analysis
